# Application configuration
PORT=7000
CONSUMER_PORT=7000
PRODUCER_PORT=7001
STREAM_URL=https://stream.wikimedia.org/v2/stream/recentchange
LOG_LEVEL=info

#Redpanda configuration
KAFKA_BROKERS=redpanda:29092
KAFKA_TOPIC=wikistats
KAFKA_RETRY_ATTEMPTS=5
KAFKA_MAX_POLL_RECORDS=100
KAFKA_CONSUMER_GROUP_ID=wikistats-consumers

# Core Redpanda Console settings (v3.x+)
REDPANDA_KAFKA_BROKERS=redpanda:29092

# Protobuf Specifics
REDPANDA_KAFKA_PROTO_ENABLED=true
REDPANDA_KAFKA_PROTO_IMPORTPATHS=/etc/protobuf,google

# Mapping (Index 0)
REDPANDA_KAFKA_PROTO_MAPPINGS_0_TOPIC=wikistats
REDPANDA_KAFKA_PROTO_MAPPINGS_0_MESSAGE_NAME=wiki.WikiStreamMessage

# Database configuration
DB_HOST=scylla
DB_KEYSPACE=wikistats